<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginVertical="10dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/glass_border"
    app:cardBackgroundColor="@color/glass_surface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Status Indicator Ring -->
        <FrameLayout
            android:id="@+id/flStatusBase"
            android:layout_width="52dp"
            android:layout_height="52dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:id="@+id/vStatusIndicator"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/status_circle"
                android:backgroundTint="@color/slate_100" />

            <ImageView
                android:id="@+id/ivServerIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_server_minimal"
                app:tint="@color/slate_900" />
        </FrameLayout>

        <!-- Information Block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/flStatusBase"
            app:layout_constraintEnd_toStartOf="@+id/ivOptions"
            app:layout_constraintStart_toEndOf="@id/flStatusBase"
            app:layout_constraintTop_toTopOf="@id/flStatusBase">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Web Instance"
                android:textColor="@color/slate_900"
                android:textSize="17sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="-0.01" />

            <TextView
                android:id="@+id/tvIpPort"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="192.168.1.1"
                android:textColor="@color/slate_500"
                android:textSize="13sp"
                android:fontFamily="sans-serif-light" />
        </LinearLayout>

        <!-- Minimal Options -->
        <ImageView
            android:id="@+id/ivOptions"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:src="@drawable/ic_dots_minimal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/slate_300" />

        <!-- Cyber Badge (Absolute Minimalist) -->
        <TextView
            android:id="@+id/tvStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="OPERATIONAL"
            android:textColor="@color/slate_500"
            android:textSize="10sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/flStatusBase" />

        <!-- Hidden but present for logic -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvStatusText" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
