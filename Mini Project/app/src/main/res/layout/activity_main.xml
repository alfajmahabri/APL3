<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/glass_white"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/glass_white"
        app:elevation="0dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tvAppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registry"
                android:textColor="@color/slate_900"
                android:textSize="34sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.04" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tvAppTitle"
                android:layout_marginTop="2dp"
                android:text="ACTIVE NETWORK MONITOR"
                android:textColor="@color/slate_500"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.15" />

            <!-- Aesthetic Navigation Dot -->
            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_alignParentEnd="true"
                android:layout_alignTop="@id/tvAppTitle"
                android:layout_marginTop="14dp"
                android:background="@drawable/status_circle"
                android:backgroundTint="@color/cyber_green" />
        </RelativeLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvVms"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- Pure Minimalist Empty State -->
    <LinearLayout
        android:id="@+id/llEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="48dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ø"
            android:textColor="@color/slate_300"
            android:textSize="64sp"
            android:fontFamily="sans-serif-thin" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="System Isolated"
            android:textColor="@color/slate_900"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Connect an endpoint to start\nreal-time data acquisition."
            android:textColor="@color/slate_500"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Aesthetic Floating Action -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        app:backgroundTint="@color/slate_900"
        app:elevation="4dp"
        app:fabCustomSize="72dp"
        app:maxImageSize="36dp"
        app:srcCompat="@drawable/ic_add_minimal"
        app:tint="@color/white"
        app:borderWidth="0dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
